generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  Active
  Inactive
}

enum MessageStatus {
  Sent
  Read
}

model app_users {
  id          Int             @id @default(autoincrement())
  email       String          @unique
  password    String
  username    String
  userTag     String          @unique 
  avatar      String?
  role        String          @default("user")
  country     String?
  nativeLang  String?
  targetLang  String?
  level       String          @default("A2")
  createdAt   DateTime        @default(now())
  status      UserStatus      @default(Inactive)

  messagesSent   chat_messages[] @relation("SentMessages")
  dailyTasks     daily_tasks[]
  room_users     room_users[]
  sessions       sessions[]
  user_progress  user_progress[]
  daily_generated_tasks daily_generated_tasks[]
  archivedTasks archived_practice_tasks[]
}

model chat_rooms {
  id         Int           @id @default(autoincrement())
  theme      String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime?     @default(now()) @updatedAt
  isOpen     Boolean   @default(true)
  maxUsers   Int       @default(2)
  room_users room_users[]
  messages   chat_messages[]
}

model room_users {
  user    app_users   @relation(fields: [userId], references: [id])
  userId  Int

  chat_room chat_rooms @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId  Int

  @@id([userId, roomId])
}

model chat_messages {
  id         Int           @id @default(autoincrement())
  content    String
  createdAt  DateTime      @default(now())
  status     MessageStatus @default(Sent)

  sender     app_users     @relation("SentMessages", fields: [senderId], references: [id])
  senderId   Int

  room       chat_rooms    @relation(fields: [roomId], references: [id])
  roomId     Int

  corrections corrections[]
}

model daily_tasks {
  id         Int        @id @default(autoincrement())
  title      String
  content    String
  type       String
  createdAt  DateTime   @default(now())
  completed  Boolean    @default(false)

  user       app_users  @relation(fields: [userId], references: [id])
  userId     Int
}

model corrections {
  id         Int           @id @default(autoincrement())
  original   String
  corrected  String
  explanation String?
  type        String

  message    chat_messages @relation(fields: [messageId], references: [id])
  messageId  Int
  createdAt  DateTime      @default(now())
}

model correction_theory {
  type      String   @id // 'tense', 'article' і т.д.
  title     String
  content   String
  createdAt DateTime @default(now())
}

model user_progress {
  id        Int       @id @default(autoincrement())
  userId    Int
  date      DateTime  @default(now())
  score     Int
  total     Int
  createdAt DateTime  @default(now())

  user      app_users @relation(fields: [userId], references: [id])
  user_progress user_progress_archive[]

  @@unique([userId, date])
}

model sessions {
  id         Int        @id @default(autoincrement())
  token      String
  createdAt  DateTime   @default(now())
  expiresAt  DateTime

  user       app_users  @relation(fields: [userId], references: [id])
  userId     Int
}

model daily_generated_tasks {
  id         Int        @id @default(autoincrement())
  userId     Int
  date       DateTime   @default(now())
  question   String
  options    String[]
  correct    String
  explanation String
  type       String
  answer String?

  user       app_users @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model archived_practice_tasks {
  id         Int      @id @default(autoincrement())
  userId     Int
  date       DateTime
  question   String
  options    String[]
  correct    String
  explanation String
  type       String
  answer     String?  // відповідь користувача

  archived_users user_progress_archive[] // опційно
  user app_users @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model user_progress_archive {
  id              Int      @id @default(autoincrement())
  userProgressId  Int
  archivedTaskId  Int

  user_progress         user_progress          @relation(fields: [userProgressId], references: [id])
  archived_practice     archived_practice_tasks @relation(fields: [archivedTaskId], references: [id])

  @@index([userProgressId])
  @@index([archivedTaskId])
  @@unique([userProgressId, archivedTaskId])
}
